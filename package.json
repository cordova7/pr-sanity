{
  "name": "pr-sanity",
  "version": "0.1.1",
  "description": "Architecture drift detection for .NET codebases",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pr-sanity": "./dist/index.js"
  },
  "files": [
    "dist/",
    "action.yml",
    "README.md",
    ".pr-sanity.example.yml"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node test/run-fixtures.js",
    "test:fixtures": "npm run build && node test/run-fixtures.js",
    "test:verbose": "npm run build && node test/run-fixtures.js --verbose",
    "test:regression": "npm run build && node test/regression/regression.js",
    "test:action": "npm run build && node test/action/run-action-test.js",
    "demo": "node dist/index.js health --demo",
    "demo:drift": "bash test/demo-drift.sh"
  },
  "keywords": [
    "dotnet",
    "csharp",
    "architecture",
    "cli",
    "static-analysis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cordova7/pr-sanity.git"
  },
  "homepage": "https://github.com/cordova7/pr-sanity#readme",
  "bugs": {
    "url": "https://github.com/cordova7/pr-sanity/issues"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "js-yaml": "^5.1.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.30",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
